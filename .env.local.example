# Required
SECRET_KEY_BASE=your_secret_key_here

# Database (choose one option)
# Option 1:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/droplet_template_development

# Option 2: Individual variables
# DB_HOST=localhost
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_PORT=5432

# Environment
RAILS_ENV=development

# Docker users: use host.docker.internal instead of localhost
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/droplet_template_development

# Admin ops endpoint (PATCH /admin_api/company) — bearer token to update an
# installation's mutable fields (name, fluid_shop, active). Generate with:
#   openssl rand -hex 32
ADMIN_API_TOKEN=

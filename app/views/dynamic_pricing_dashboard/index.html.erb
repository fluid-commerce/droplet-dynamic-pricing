<% content_for :head do %>
  <%= vite_typescript_tag 'dashboard.tsx' %>
<% end %>

<%
  cart_events_payload = @cart_pricing_events.map do |e|
    {
      id: e.id,
      cart_id: e.cart_id,
      email_safe: e.email_safe,
      event_type: e.event_type,
      items_count: e.items_count,
      cart_total: e.cart_total&.to_s,
      preferred_pricing_applied: e.preferred_pricing_applied,
      created_at: e.created_at.iso8601,
    }
  end

  transactions_payload = @transactions.map do |t|
    {
      id: t.id,
      customer_id: t.customer_id,
      external_id: t.external_id,
      previous_type: t.previous_type,
      new_type: t.new_type,
      source: t.source,
      upgraded: t.upgraded?,
      downgraded: t.downgraded?,
      created_at: t.created_at.iso8601,
    }
  end
%>

<div
  id="dashboard-root"
  data-company-name="<%= @company.name %>"
  data-dri="<%= @dri %>"
  data-active-tab="<%= @active_tab %>"
  data-page="<%= @page %>"
  data-per-page="<%= @per_page %>"
  data-stats="<%= @stats.to_json %>"
  data-cart-events="<%= cart_events_payload.to_json %>"
  data-cart-total-count="<%= @cart_total_count %>"
  data-transactions="<%= transactions_payload.to_json %>"
  data-tx-total-count="<%= @tx_total_count %>"
  data-integration-settings-url="<%= admin_integration_setting_path(dri: @dri) %>"
  data-base-url="<%= dashboard_path(dri: @dri) %>"
></div>
